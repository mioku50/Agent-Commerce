{
  "name": "arc-agent-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Arc Agent Commerce API Store Demo for x402-powered USDC payments by AI agents.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "generate-wallets": "node --experimental-transform-types --no-warnings generate-wallets.mts",
    "agent": "node --experimental-transform-types --no-warnings --env-file=.env.local agent.mts",
    "gateway:balance": "node --experimental-transform-types --no-warnings --env-file=.env.local scripts/gateway-balance.mts",
    "agents:rebuild": "node --experimental-transform-types --no-warnings --env-file=.env.local scripts/rebuild-agent-passports.mts",
    "db:migrate": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/agent-db-migrate.mts",
    "db:verify": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/agent-db-verify.mts",
    "proofs:recover": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/recover-onchain-proofs.mts",
    "proofs:smoke": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/proof-registry-smoke.mts",
    "hosted:test": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/hosted-runner-db-tests.mts",
    "hosted:workflow-test": "node --experimental-transform-types --no-warnings scripts/hosted-workflow-tests.mts",
    "hosted:recover": "node --experimental-transform-types --no-warnings --env-file-if-exists=.env.local scripts/recover-hosted-agent-job.mts",
    "hosted:browser-smoke": "node --experimental-transform-types --no-warnings scripts/hosted-browser-smoke.mts",
    "review:smoke": "node --experimental-transform-types --no-warnings scripts/review-smoke.mts"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^2.0.4",
    "@langchain/core": "^1.1.32",
    "@langchain/openai": "^1.2.13",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.8.2",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.61.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
