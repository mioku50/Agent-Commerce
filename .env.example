# Agent DB through the Vercel Supabase integration.
# Legacy NEXT_PUBLIC_SUPABASE_* and SUPABASE_SERVICE_ROLE_KEY names remain
# temporary runtime fallbacks, but new deployments should use AGENT_DB.
NEXT_PUBLIC_AGENT_DB_SUPABASE_URL=your-agent-db-project-url
NEXT_PUBLIC_AGENT_DB_SUPABASE_PUBLISHABLE_KEY=your-agent-db-publishable-key
AGENT_DB_SUPABASE_URL=your-agent-db-project-url
AGENT_DB_SUPABASE_SECRET_KEY=your-agent-db-server-secret-key
# AGENT_DB_SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# AGENT_DB_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/postgres?sslmode=require

# App URL used by the buyer-agent runner
BASE_URL=http://localhost:3000

# x402 / Circle Nanopayments
# Run `npm run generate-wallets` to auto-generate both seller and buyer wallets
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_DEMO_BUYER_ADDRESS=0xYourBuyerWalletAddress
SELLER_ADDRESS=0xYourWalletAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# Phase 17 onchain proof registry (server-only attester)
# Deploy from contracts/ with an encrypted Foundry keystore, then set the address.
AGENT_COMMERCE_PROOF_REGISTRY_ADDRESS=0xYourProofRegistryAddress
AGENT_COMMERCE_PROOF_ATTESTER_PRIVATE_KEY=0xYourServerAttesterPrivateKey

# Foundry deploy script inputs (public addresses, not private keys)
PROOF_REGISTRY_OPERATOR_ADDRESS=0xYourOperatorAddress
PROOF_REGISTRY_ATTESTER_ADDRESS=0xYourServerAttesterAddress

# Buyer wallet (for the payment agent)
BUYER_ADDRESS=0xYourBuyerWalletAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# Hosted buyer-agent (server-only key and HMAC secret)
HOSTED_AGENT_ADDRESS=0xYourHostedBuyerAddress
HOSTED_AGENT_PRIVATE_KEY=0xYourHostedBuyerPrivateKey
HOSTED_AGENT_RATE_LIMIT_SECRET=replace-with-a-long-random-server-secret
HOSTED_AGENT_ALLOWED_SERVICE_SLUGS=premium-quote,text-analyzer,pyth-market-price

# User-facing hosted checkout. The connected browser wallet confirms at most
# one native-USDC payment; the hosted wallet above separately pays downstream
# APIs through x402. SELLER_ADDRESS is used if the treasury override is absent.
HOSTED_WORKFLOW_TREASURY_ADDRESS=0xYourWorkflowTreasuryAddress
HOSTED_WORKFLOW_PLATFORM_FEE_USDC=0.0007
HOSTED_WORKFLOW_MAX_PRICE_USDC=0.005
HOSTED_WORKFLOW_SPONSORED_QUOTA=1
HOSTED_WORKFLOW_QUOTE_EXPIRY_SECONDS=600

# Agent runner controls
AGENT_DEPOSIT_USDC=1
# AGENT_PRIVATE_KEY=0xExistingEphemeralAgentPrivateKey
# AGENT_SKIP_FUNDING=1
# AGENT_SKIP_DEPOSIT=1
# AGENT_FETCH_RETRIES=3
# AGENT_FETCH_TIMEOUT_MS=30000
# AGENT_MAX_IN_FLIGHT=1
# AGENT_POST_DEPOSIT_WAIT_MS=30000

# Phase 3 buyer-agent examples
# npm run agent -- --task "Prepare a market context report" --limit 0.05
# AGENT_PRIVATE_KEY=0x... AGENT_SKIP_FUNDING=1 AGENT_SKIP_DEPOSIT=1 npm run agent -- --task "Create a small proof of agent commerce" --limit 0.001

# Phase 4 Seller Creator Mode uses the same Supabase service role key
# for server-side writes to public.store_services. Never expose it client-side.

# Optional hosted Final Report synthesis (server-only)
# Only the openai-compatible protocol is supported. The deterministic report
# remains available when any value is missing or the provider call fails.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.freemodel.dev/v1
LLM_API_KEY=your-freemodel-api-key
LLM_MODEL=gpt-5.4-mini

# Live provider adapter (server-only Vercel Sensitive value)
PYTH_API_KEY=your-pyth-api-key
